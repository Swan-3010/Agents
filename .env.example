APP_ENV=dev
TZ=Europe/Moscow

# --- IMAP / SMTP (Yandex Mail) ---
IMAP_HOST=imap.yandex.com
IMAP_PORT=993
SMTP_HOST=smtp.yandex.com
SMTP_PORT=465

# --- Учётные данные ящика ---
# EMAIL_ADDRESS — адрес ящика Yandex (откуда читаем и отправляем)
# EMAIL_APP_PASSWORD — app-пароль из Яндекс ID → Безопасность → Пароли приложений
EMAIL_ADDRESS=sinbox1@yandex.ru
EMAIL_APP_PASSWORD=vxvyezotjlsynjmr

# --- Фильтр чеков ---
RECEIPT_SENDER=noreply@check.yandex.ru
LOOKBACK_DAYS=31

# --- Отчёты ---
REPORT_TO_EMAIL=swan_d@mail.ru
REPORT_FROM_EMAIL=sinbox1@yandex.ru

# --- Тестирование (Integration Tests) ---
# Используем основной почтовый ящик в readonly режиме
# IMAP/SMTP тесты требуют реальных credentials
TEST_IMAP_HOST=imap.yandex.com
TEST_IMAP_PORT=993
TEST_SMTP_HOST=smtp.yandex.com
TEST_SMTP_PORT=465

# Тестовый email (используем основной ящик)
TEST_EMAIL_ADDRESS=sinbox1@yandex.ru
TEST_EMAIL_PASSWORD=vxvyezotjlsynjmr

# Куда отправлять тестовые отчёты
TEST_REPORT_TO_EMAIL=swan_d@mail.ru

# Безопасность: не удалять/изменять письма в тестах
TESTS_READONLY_MODE=true

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000

# --- Ollama LLM ---
# Если запуск через docker-compose — http://ollama:11434
# Если Ollama запущен локально (WSL2/натив) — http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

LOG_LEVEL=INFO
